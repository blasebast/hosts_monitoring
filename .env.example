# Hosts Monitoring Configuration

# Path to /etc/hosts file (or custom hosts format file)
HOSTS_FILE=/etc/hosts

# Output directory for Prometheus metrics
# Node Exporter textfile collector directory
OUTPUT_DIR=/var/lib/node_exporter/textfile_collector

# Output file base name
OUTPUT_FILE_BASE=node_network_hosts_up.prom

# Ping timeout in seconds
PING_TIMEOUT=1

# Log directory for application logs
LOG_DIR=/tmp

# ARP command path (may differ on some systems)
ARP_CMD=/usr/sbin/arp

# Python logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
